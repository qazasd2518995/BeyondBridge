# App
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
PLATFORM_URL=http://localhost:3000/platform
CORS_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
DYNAMODB_TABLE=beyondbridge
S3_BUCKET=beyondbridge-files
EMAIL_FROM=noreply@beyondbridge.com

# Seed / bootstrap
ADMIN_DEFAULT_PASSWORD=ChangeMe-StrongPassword

# LTI
LTI_PLATFORM_ISSUER=https://beyondbridge.edu
LTI_INSTANCE_GUID=beyondbridge.edu
